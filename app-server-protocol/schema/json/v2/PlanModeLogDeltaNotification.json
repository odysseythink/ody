{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "PlanModeLogKind": {
      "enum": [
        "rigorReminder",
        "splitStarted",
        "splitContinued",
        "splitCompleted",
        "finalReview",
        "designCompletenessCheck",
        "modeTransition",
        "subAgentDelegation"
      ],
      "type": "string"
    }
  },
  "description": "Structured planning log delta for Plan/Design mode. Emitted to surface rigor reminders, split checks, completeness gates, and mode transitions.",
  "properties": {
    "detail": {
      "type": [
        "string",
        "null"
      ]
    },
    "eventId": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/PlanModeLogKind"
    },
    "message": {
      "type": "string"
    },
    "occurredAtMs": {
      "format": "int64",
      "type": "integer"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "eventId",
    "kind",
    "message",
    "occurredAtMs",
    "threadId",
    "turnId"
  ],
  "title": "PlanModeLogDeltaNotification",
  "type": "object"
}